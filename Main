
CREATE DATABASE Reservation;
USE Reservation;

CREATE TABLE Vendor (
   vendor_id VARCHAR(10),
   vendor_name VARCHAR(50),
   phone_vnum VARCHAR(10),
   PRIMARY KEY (vendor_id)
);
CREATE TABLE Booth (
   booth_id VARCHAR(10),
   booth_size VARCHAR(50),
   booth_rent INT,
   PRIMARY KEY (booth_id)
);
CREATE TABLE Staff (
   staff_id VARCHAR(10),
   staff_name VARCHAR(50),
   position VARCHAR(50),
   phone_snum VARCHAR(10),
   PRIMARY KEY(staff_id)
);
CREATE TABLE Reservation (
   reservation_id VARCHAR(10),
   vendor_id VARCHAR(10),
   reservation_date DATE,
   booth_id VARCHAR(10),
   FOREIGN KEY (vendor_id) REFERENCES Vendor(vendor_id),
   FOREIGN KEY (booth_id) REFERENCES Booth(booth_id),
   PRIMARY KEY(reservation_id)
);
CREATE TABLE Confirmation (
   confirm_id VARCHAR(10),
   drawlot_date DATE,
   drawlot_location VARCHAR(100),
   vendor_id VARCHAR(10),
	FOREIGN KEY (vendor_id) REFERENCES Vendor(vendor_id),
    PRIMARY KEY (confirm_id)
    
);
CREATE TABLE Inspection (
   inspection_id VARCHAR(10),
   reservation_id VARCHAR(10),
   confirm_id VARCHAR(10),
   staff_id VARCHAR(10),
   inspection_status ENUM('Pass','Incorrect'),
   FOREIGN KEY (confirm_id) REFERENCES Confirmation(confirm_id),
   FOREIGN KEY (reservation_id) REFERENCES Reservation(reservation_id),
   FOREIGN KEY (staff_id) REFERENCES Staff(staff_id),
   PRIMARY KEY (inspection_id)
);
CREATE TABLE Payment (
   payment_id VARCHAR(10),
   confirm_id VARCHAR(10),
   payment_status ENUM('Deposit paid','Payment made'),
	FOREIGN KEY (confirm_id) REFERENCES Confirmation(confirm_id),
    PRIMARY KEY (payment_id)
);


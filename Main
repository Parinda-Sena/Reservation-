SELECT * FROM Vendor;
SELECT * FROM Booth;
SELECT Vendor.vendor_name, Booth.booth_id, Booth.booth_rent
FROM Reservation
JOIN Vendor ON Reservation.vendor_id = Vendor.vendor_id
JOIN Booth ON Reservation.booth_id = Booth.booth_id
WHERE Booth.booth_rent > 1500;
SELECT * 
FROM Booth
WHERE booth_rent = (
    SELECT MIN(booth_rent) 
    FROM Booth
);
SELECT Vendor.vendor_name
FROM Vendor
JOIN Confirmation ON Vendor.vendor_id = Confirmation.vendor_id
LEFT JOIN Payment ON Confirmation.confirm_id = Payment.confirm_id
WHERE Payment.payment_status = 'Deposit paid'
OR Payment.payment_status IS NULL;
SELECT Vendor.vendor_name, Payment.payment_status
FROM Vendor
JOIN Confirmation ON Vendor.vendor_id = Confirmation.vendor_id
JOIN Payment ON Confirmation.confirm_id = Payment.confirm_id
WHERE Payment.payment_status = 'Payment made'

UNION

SELECT 'Total Paid', COUNT(*)
FROM Payment
WHERE payment_status = 'Payment made';
SELECT booth_id
FROM Reservation

UNION

SELECT CONCAT('Total Reserved: ', COUNT(booth_id))
FROM Reservation;
SELECT Staff.staff_name, COUNT(Inspection.inspection_id) AS total_inspection
FROM Staff
JOIN Inspection ON Staff.staff_id = Inspection.staff_id
GROUP BY Staff.staff_name;
SELECT Confirmation.confirm_id, Vendor.vendor_name
FROM Confirmation
JOIN Vendor ON Confirmation.vendor_id = Vendor.vendor_id

UNION

SELECT 'Total Participants', COUNT(confirm_id)
FROM Confirmation;
SELECT Vendor.vendor_name, SUM(Booth.booth_rent) AS total_payment
FROM Vendor
JOIN Reservation ON Vendor.vendor_id = Reservation.vendor_id
JOIN Booth ON Reservation.booth_id = Booth.booth_id
JOIN Confirmation ON Vendor.vendor_id = Confirmation.vendor_id
JOIN Payment ON Confirmation.confirm_id = Payment.confirm_id
WHERE Payment.payment_status = 'Payment made'
GROUP BY Vendor.vendor_name
ORDER BY total_payment DESC;


